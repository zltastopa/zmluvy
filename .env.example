# Core paths
CRZ_DB_PATH=crz.db
CRZ_DATA_DIR=data
CRZ_PDF_DIR=data/pdfs
CRZ_TEXT_DIR=data/texts
CRZ_EXTRACTIONS_DIR=data/extractions

# Extraction API
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# Downloader defaults
CRZ_DOWNLOAD_LIMIT=50000
CRZ_DOWNLOAD_MONTH=2026-03

# External tools
PDFTOTEXT_BIN=pdftotext
